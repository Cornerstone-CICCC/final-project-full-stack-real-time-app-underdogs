---
import "../styles/global.css"
import AdminSideHeader from "@components/admin/AdminSideHeader.astro"
import AdminSideMain from "@components/admin/AdminSideMain.astro"
import AdminSideFooter from "@components/admin/AdminSideFooter.astro"

const { title } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Admin</title>
  </head>

  <body class="h-screen flex overflow-hidden bg-gray-50 font-inter text-gray-800">
    <aside class="w-80 shrink-0 flex flex-col bg-white border-r border-black/5">
      <AdminSideHeader />
      <AdminSideMain />
      <AdminSideFooter />
    </aside>
    <main class="flex-1 flex flex-col overflow-hidden">
      <slot />
    </main>
  </body>
</html>
