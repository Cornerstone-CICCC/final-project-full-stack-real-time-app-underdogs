---
import ClientBaseLayout from '../layouts/ClientBaseLayout.astro';
---
<ClientBaseLayout title="HOME">
  <div class="flex items-center justify-center w-auto gap-10">
    <div class="flex flex-col items-start justify-center gap-4 max-w-80">
      <p class="font-inter text-sm font-bold text-amber-700 uppercase tracking-widest">
        Wood-Fired · Neapolitan Style
      </p>
      <h1 class="font-barlow-condensed text-7xl font-black uppercase tracking-widest">
        Stupid<br />
        Good.<br />
        Slow<br />
        Made.
      </h1>

      <div class="font-barlow text-sm text-taupe-500 leading-relaxed">
        <p>
          Hand-stretched dough, San Marzano tomatoes,<br />
          fresh buffalo mozzarella — baked in a 900°F wood-fired oven for that perfect leopard-spotted char.
        </p>
        <div class="h-px w-full bg-black/10 my-2" />
        <p>
          Every pizza is made to order — no shortcuts, no frozen dough.<br />
          We're slow because we care, and that's exactly how we like it.
        </p>
      </div>
    </div>

    <div class="flex items-center justify-center py-2">
      <img
        src="https://images.unsplash.com/photo-1581873372796-635b67ca2008?w=900&h=900&fit=crop&auto=format"
        alt="Neapolitan margherita pizza"
        class="object-contain drop-shadow-2xl max-w-120 max-h-120 w-full"
      />
    </div>
  </div>
</ClientBaseLayout>
