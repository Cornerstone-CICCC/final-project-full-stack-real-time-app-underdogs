<div id="messages-container" class="flex-1 overflow-y-auto px-7 py-6 space-y-4 bg-gray-50"></div>

<script>
  import { io } from "socket.io-client"

  const API = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000/api"
  const SOCKET_URL = import.meta.env.PUBLIC_SOCKET_URL ?? "http://localhost:3000"

  const chatId = (document.getElementById("chat-root") as HTMLElement)?.dataset.chatId
  if (!chatId) throw new Error("No chat ID")

  const container = document.getElementById("messages-container") as HTMLDivElement

  function appendMessage(from: string, text: string, time: string) {
    const isAdmin = from === "admin"
    const div = document.createElement("div")
    div.className = `flex ${isAdmin ? "justify-end" : "justify-start"}`
    div.innerHTML = `
      <div class="max-w-[68%] rounded-2xl px-4 py-3 ${isAdmin ? "bg-amber-700 text-white rounded-br" : "bg-white text-gray-800 rounded-bl shadow-sm border border-black/6"}">
        <p class="font-inter text-sm leading-relaxed">${text}</p>
        <p class="font-inter text-[10px] mt-1 ${isAdmin ? "text-orange-200" : "text-gray-400"}">${time}</p>
      </div>
    `
    container.appendChild(div)
    container.scrollTo({ top: container.scrollHeight, behavior: "smooth" })
  }

  const res = await fetch(`${API}/chats/${chatId}`, { credentials: "include" })
  if (res.ok) {
    const chat = await res.json()
    chat.messages.forEach((m: any) => appendMessage(m.from, m.text, m.time))
  }

  const socket = io(SOCKET_URL, { withCredentials: true })
  socket.emit("visitor:join", { chatId })

  socket.on("new_message", ({ chatId: incomingId, message }: any) => {
    if (incomingId !== chatId) return
    appendMessage(message.from, message.text, message.time)
  })
</script>
