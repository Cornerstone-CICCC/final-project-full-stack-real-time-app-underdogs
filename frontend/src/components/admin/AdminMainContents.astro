---
const MOCK_MESSAGES = [
  {
    id: 1,
    sender: "visitor",
    text: "Hi! I ordered a pizza an hour ago and it still hasn't arrived.",
    time: "2:31 PM",
  },
  {
    id: 2,
    sender: "admin",
    text: "Hi Sofia! I'm sorry to hear that. Let me check your order status right away.",
    time: "2:32 PM",
  },
  {
    id: 3,
    sender: "visitor",
    text: "Order number is #4521. I've been waiting for over an hour now.",
    time: "2:33 PM",
  },
  {
    id: 4,
    sender: "admin",
    text: "I can see your order is on the way — the driver is about 10 minutes away!",
    time: "2:34 PM",
  },
]
---

<div class="flex-1 overflow-y-auto px-7 py-6 space-y-4 bg-gray-50">
  {
    MOCK_MESSAGES.map((msg) => (
      <div class:list={["flex", msg.sender === "admin" ? "justify-end" : "justify-start"]}>
        <div
          class:list={[
            "max-w-[68%] rounded-2xl px-4 py-3",
            msg.sender === "admin"
              ? "bg-amber-700 text-white rounded-br"
              : "bg-white text-gray-800 rounded-bl shadow-sm border border-black/6",
          ]}
        >
          <p class="font-inter text-sm leading-relaxed">{msg.text}</p>
          <p
            class:list={[
              "font-inter text-[10px] mt-1",
              msg.sender === "admin" ? "text-orange-200" : "text-gray-400",
            ]}
          >
            {msg.time}
          </p>
        </div>
      </div>
    ))
  }
</div>
