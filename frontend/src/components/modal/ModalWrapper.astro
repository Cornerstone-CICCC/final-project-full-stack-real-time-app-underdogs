<div
  id="modal-wrapper"
  class="hidden fixed inset-0 items-center justify-center z-50 bg-black/45 backdrop-blur-sm"
>
  <div id="modal-inner" class="w-full max-w-100 transition-[max-width] duration-300 ease-in-out">
    <slot />
  </div>
</div>

<script>
  import { isModalOpen, chatModalStatus, currentChatId } from "@stores/chatModal"
  import { getVisitor } from "@utils/localStorage"
  import { createChat } from "@lib/api/chat"

  const wrapperElement = document.getElementById("modal-wrapper") as HTMLDivElement
  const innerElement = document.getElementById("modal-inner") as HTMLDivElement

  isModalOpen.subscribe(async (isOpen) => {
    if (isOpen) {
      wrapperElement.classList.remove("hidden")
      wrapperElement.classList.add("flex")

      const visitor = getVisitor()
      if (visitor) {
        chatModalStatus.set("chat")
        try {
          const res = await createChat({
            visitorId: visitor.visitorId,
            firstName: visitor.firstName,
            lastName: visitor.lastName,
          })
          if (res.chatId) currentChatId.set(res.chatId)
        } catch {
          chatModalStatus.set("register")
        }
      } else {
        chatModalStatus.set("register")
      }
    } else {
      wrapperElement.classList.remove("flex")
      wrapperElement.classList.add("hidden")
      chatModalStatus.set("register")
      currentChatId.set(null)
    }
    document.body.classList.toggle("overflow-hidden", isOpen)
  })

  chatModalStatus.subscribe((status) => {
    if (status === "register") {
      innerElement.classList.replace("max-w-160", "max-w-100")
    } else {
      innerElement.classList.replace("max-w-100", "max-w-160")
    }
  })

  document.querySelectorAll("[data-modal-btn]").forEach((btn) => {
    btn.addEventListener("click", () => {
      isModalOpen.set(!isModalOpen.get())
    })
  })
</script>
