---
import Icon from '@components/Icon.astro';
---

<div id="register-content" class="hidden relative bg-white rounded-2xl shadow-2xl p-10 w-full">
  <button data-modal-btn class="absolute top-4 right-4 text-taupe-400 hover:text-taupe-600 transition-colors p-1 cursor-pointer">
    <Icon name="X" width="18" height="18" />
  </button>

  <h2 class="font-barlow-condensed text-3xl font-black mb-2 tracking-wider">
    Open a ticket
  </h2>
  <p class="font-inter text-sm text-taupe-500 mb-4">
    Tell us your name to start chatting with an agent.
  </p>

  <div class="space-y-4 mb-8">
    <div>
      <label class="block font-inter text-sm font-semibold text-taupe-700 mb-1">
        First name
      </label>
      <input
        type="text"
        id="first-name"
        placeholder="e.g. Margherita"
        class="font-inter w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-taupe-900 placeholder-gray-300 bg-gray-50 focus:outline-none focus:border-orange-300 focus:ring-2 focus:ring-orange-100 transition"
      />
    </div>
    <div>
      <label class="block font-inter text-sm font-semibold text-taupe-700 mb-1">
        Last name
      </label>
      <input
        type="text"
        id="last-name"
        placeholder="e.g. Romano"
        class="font-inter w-full border border-gray-200 rounded-lg px-4 py-3 text-sm text-taupe-900 placeholder-gray-300 bg-gray-50 focus:outline-none focus:border-orange-300 focus:ring-2 focus:ring-orange-100 transition"
      />
    </div>
  </div>

  <button id="start-chat-btn" class="font-inter w-full bg-amber-700 text-white text-sm font-semibold py-3 rounded-md hover:opacity-90 transition-opacity cursor-pointer">
    Start chat
  </button>
</div>

<script>
  import { chatModalStatus, currentChatId } from '@stores/chatModal';
  import { createChat } from '@lib/api/chat';
  import { ApiError } from '@lib/api/client';
  import { getOrCreateVisitorId } from '@utils/localStorage';

  const contentElement = document.getElementById('register-content');
  const btnElement = document.getElementById('start-chat-btn');

  chatModalStatus.subscribe((status) => {
    contentElement?.classList.toggle('hidden', status !== 'register');
  });

  btnElement?.addEventListener('click', async () => {
    try {
      const visitorId = getOrCreateVisitorId();
      const res = await createChat(visitorId);
      if (!res.id) throw new Error('Invalid response: missing id');
      currentChatId.set(res.id)
      chatModalStatus.set('chat');
    } catch (error: unknown) {
      if (error instanceof ApiError) {
        console.error(`API ERROR ${error.status}:`, error.message);
      } else {
        console.error(error)
      }
    }
  });
</script>
