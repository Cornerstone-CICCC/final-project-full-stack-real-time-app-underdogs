---
import AdminBaseLayout from "@layouts/AdminBaseLayout.astro"
---

<AdminBaseLayout title="Admin">
  <div class="flex-1 flex items-center justify-center">
    <div class="text-center">
      <p class="font-inter text-sm text-gray-400">Select a ticket to get started</p>
    </div>
  </div>
</AdminBaseLayout>

<script>
  const API = import.meta.env.PUBLIC_API_URL ?? "http://localhost:3000/api"

  const res = await fetch(`${API}/auth/me`, { credentials: "include" })
  if (!res.ok) {
    window.location.href = "/admin/login"
  }
</script>
